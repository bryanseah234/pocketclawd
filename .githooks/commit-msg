#!/usr/bin/env node
import { readFileSync } from 'node:fs';

const file = process.argv[2];
const msg = readFileSync(file, 'utf8').split('\n')[0].trim();
const ok = /^(feat|fix|docs|style|refactor|test|chore|perf|ci|build)(\([^)]+\))?: .+/.test(msg);
if (!ok) {
  process.stderr.write(
    `\nERROR: commit message does not follow Conventional Commits format.\n` +
    `  Got: "${msg}"\n` +
    `  Format: <type>[(scope)]: <description>\n` +
    `  Types: feat fix docs style refactor test chore perf ci build\n\n`,
  );
  process.exit(1);
}
