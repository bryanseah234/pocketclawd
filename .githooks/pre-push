#!/usr/bin/env bash
set -e

# Get current branch name
BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)

echo "🔍 Validating branch name and running pre-push checks..."

# Branch naming convention (aligned with CONTRIBUTING.md)
VALID_BRANCH_REGEX="^(main|master|develop|development|staging|chore/.+|release\/[0-9]{4}-[0-9]{2}-[0-9]{2}|feature\/.+|fix\/.+|bugfix\/.+|hotfix\/.+)$"

if [[ ! $BRANCH_NAME =~ $VALID_BRANCH_REGEX ]]; then
    echo "❌ Error: Branch name '$BRANCH_NAME' does not follow the naming convention."
    echo ""
    echo "Valid patterns:"
    echo "  main/master/develop/staging  (protected branches)"
    echo "  release/yyyy-mm-dd           (release branches)"
    echo "  feature/description          (new features)"
    echo "  chore/description            (maintenance)"
    echo "  fix/description              (bug fixes)"
    echo "  bugfix/description           (bug fixes)"
    echo "  hotfix/description           (urgent fixes)"
    exit 1
fi

# Prevent direct push to protected branches
PROTECTED_BRANCHES="^(main|master|develop|development|staging)$"
if [[ $BRANCH_NAME =~ $PROTECTED_BRANCHES ]]; then
    echo "⚠️  Warning: You are pushing to protected branch '$BRANCH_NAME'."
    echo "   This should typically be done through pull requests."
    echo ""
    read -p "Continue? (y/N): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "❌ Push cancelled."
        exit 1
    fi
fi

# Run typecheck (fast feedback before push)
echo "🔍 Running typecheck..."
if ! pnpm run typecheck; then
    echo "❌ Error: Typecheck failed. Please fix type errors before pushing."
    exit 1
fi

# Check for secrets/sensitive data in staged changes
echo "🔍 Checking for potential secrets..."
if git diff @{push}.. -- . 2>/dev/null | grep -iE "(password|secret|api_key|private_key|token).*=.*['\"][^'\"]{8,}['\"]" > /dev/null 2>&1; then
    echo "⚠️  Warning: Potential secrets detected in changes."
    echo "   Please review before pushing."
fi

echo "✅ All pre-push checks passed!"
