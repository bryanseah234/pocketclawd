{
  "name": "nanoclaw",
  "version": "2.0.64",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "dist/index.js",
  "bin": {
    "ncl": "bin/ncl"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "setup:auto": "tsx setup/auto.ts",
    "ncl": "tsx src/cli/client.ts",
    "chat": "tsx scripts/chat.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "svc": "cmd /c powershell -NoProfile -ExecutionPolicy Bypass -File scripts/service/status.ps1",
    "svc:status": "cmd /c powershell -NoProfile -ExecutionPolicy Bypass -File scripts/service/status.ps1",
    "svc:tail": "cmd /c powershell -NoProfile -ExecutionPolicy Bypass -File scripts/service/status.ps1 -Follow",
    "svc:install": "cmd /c powershell -NoProfile -ExecutionPolicy Bypass -File scripts/service/install.ps1",
    "svc:install:elevated": "cmd /c powershell -NoProfile -ExecutionPolicy Bypass -File scripts/service/install-elevated.ps1",
    "svc:install:dry": "cmd /c powershell -NoProfile -ExecutionPolicy Bypass -File scripts/service/install.ps1 -DryRun",
    "svc:uninstall": "cmd /c powershell -NoProfile -ExecutionPolicy Bypass -File scripts/service/uninstall.ps1",
    "svc:uninstall:elevated": "cmd /c powershell -NoProfile -ExecutionPolicy Bypass -File scripts/service/uninstall-elevated.ps1",
    "svc:uninstall:purge": "cmd /c powershell -NoProfile -ExecutionPolicy Bypass -File scripts/service/uninstall.ps1 -Purge",
    "svc:export": "cmd /c powershell -NoProfile -ExecutionPolicy Bypass -File scripts/service/migrate-export.ps1",
    "ingest:now": "tsx scripts/ingest-now.ts",
    "tg:login": "tsx scripts/telegram-mtproto-login.ts"
  },
  "dependencies": {
    "@azure/msal-node": "3.5.0",
    "@chat-adapter/telegram": "4.27.0",
    "@clack/core": "^1.2.0",
    "@clack/prompts": "^1.2.0",
    "@octokit/rest": "21.1.1",
    "@onecli-sh/sdk": "^0.5.0",
    "@slack/web-api": "7.8.0",
    "@types/pdfkit": "^0.17.6",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "better-sqlite3": "11.10.0",
    "chat": "4.27.0",
    "chokidar": "4.0.3",
    "cron-parser": "5.5.0",
    "docx": "9.5.0",
    "googleapis": "146.0.0",
    "imapflow": "1.0.190",
    "input": "^1.0.1",
    "kleur": "^4.1.5",
    "mailparser": "3.7.4",
    "mammoth": "1.11.0",
    "pdf-parse": "1.1.1",
    "pdfkit": "^0.18.0",
    "pino": "9.6.0",
    "pptxgenjs": "4.0.1",
    "qrcode": "1.5.4",
    "sharp": "0.34.4",
    "telegram": "^2.26.22",
    "tsdav": "2.2.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/qrcode": "1.5.6",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
