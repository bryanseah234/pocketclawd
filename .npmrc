# Safety net — pnpm-workspace.yaml has the authoritative minimumReleaseAge (4320 min = 3 days)
# This .npmrc value is a fallback if npm is ever invoked directly
minReleaseAge=3d

# exFAT drive (X:) does not support symlinks — pnpm needs hoisted linker on Windows exFAT
node-linker=hoisted

# Enforce the Node version range in package.json engines (pin to Node 22;
# better-sqlite3@12 has no prebuilt for Node 26 / ABI 147).
engine-strict=true
