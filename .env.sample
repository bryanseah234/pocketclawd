# ========================================
# NanoClaw — Multi-User WhatsApp AI Assistant (AWS Cloud)
# ========================================
# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit secrets.
#
# In production (EC2), only NANOCLAW_ENV and AWS_REGION are needed.
# All other config is loaded from AWS Secrets Manager (nanoclaw/app-config).

# --- Cloud Mode (REQUIRED) ---
# Activates AWS services: Secrets Manager, DynamoDB, OpenSearch, ElastiCache, S3, Bedrock
NANOCLAW_ENV=cloud
AWS_REGION=ap-southeast-1

# --- AWS Credentials ---
# On EC2: uses instance IAM role (no config needed)
# On dev machine: use a named profile from ~/.aws/config
# AWS_PROFILE=default

# --- S3 Bucket (created by Terraform) ---
# Format: nanoclaw-data-{account_id}
DATA_BUCKET=nanoclaw-data-<your-account-id>

# --- ElastiCache Redis (created by Terraform) ---
REDIS_URL=redis://<your-elasticache-endpoint>:6379

# --- WhatsApp (Baileys — the user-facing channel) ---
# Use a DEDICATED number — unofficial protocol, ban risk on personal accounts.
# QR auth on first run via admin dashboard; session persisted to S3.
# WHATSAPP_PHONE_NUMBER=+65XXXXXXXX

# --- Telegram (optional secondary channel) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_CHAT_ID=

# --- Admin Dashboard ---
# HTTP Basic Auth credentials for /admin endpoint
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=<strong-random-password>

# --- Runtime Config ---
BATCH_WINDOW_MS=5000
CONTAINER_MEMORY_LIMIT=512m

# --- Secrets Manager Reference ---
# All of the following are loaded from nanoclaw/app-config at runtime:
#   redis_host, redis_port, redis_password, redis_tls
#   dynamodb_chat_messages_table, dynamodb_webhook_tokens_table,
#   dynamodb_user_preferences_table, dynamodb_system_errors_table
#   opensearch_endpoint, opensearch_index_name
#   s3_data_bucket
#   llm_model_id, llm_region
#   ecr_registry_url, ecr_agent_image
#   BEDROCK_EMBEDDING_MODEL_ID
#   NOTIFICATION_TIMEZONE
#   RATE_LIMIT_GLOBAL_PER_HOUR, RATE_LIMIT_PER_USER_PER_MIN
#   WHATSAPP_SESSION_S3_PREFIX
