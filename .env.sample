# ========================================
# PocketClaw — Personal AI Assistant
# ========================================
# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit secrets.

# --- Azure (existing pocketclaw template, optional for cloud datasets) ---
AZURE_STORAGE_ACCOUNT=
AZURE_KEY_VAULT=
AZURE_URL=
SECRET_NAME=

# --- Claude auth (one of OAuth or API key; OAuth preferred for Claude Max subscription) ---
# OAuth: run `claude /login` inside the container once; the token is written here.
# https://www.anthropic.com/claude-code — Claude Max plan ($100/mo)
CLAUDE_CODE_OAUTH_TOKEN=
# API key fallback (pay-per-use; leave blank if using OAuth above).
# https://console.anthropic.com
ANTHROPIC_API_KEY=
# Set true if you authenticated via the Claude Max subscription path.
CLAUDE_MAX_SUBSCRIPTION=true

# --- Telegram (primary interface) ---
# 1. Create bot via @BotFather: /newbot → save token
# 2. Send /start to @userinfobot → save your chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# --- WhatsApp (secondary interface, via Baileys) ---
# Use a SECONDARY number — unofficial protocol, ban risk on main account.
# QR auth on first run; session persisted to wa-session named volume.
# Auth session directory (Baileys). Defaults to ~/.pocketclaw/whatsapp.
# Override if you have an existing session store elsewhere.
# WHATSAPP_AUTH_DIR=

# --- Google OAuth (Gmail / Calendar / Contacts ingestion) ---
# https://console.cloud.google.com → OAuth 2.0 → Desktop app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft Graph (Outlook Mail / Calendar / Contacts ingestion) ---
# https://portal.azure.com → App registrations → register desktop app
MS_CLIENT_ID=

# --- Apple iCloud (Mail / Calendar / Contacts ingestion via IMAP/CalDAV/CardDAV) ---
# https://appleid.apple.com → Security → App-Specific Passwords → generate
APPLE_ID_EMAIL=
APPLE_APP_PASSWORD=

# --- Local services ---
# Ollama runs on the host, accessible from container via host.docker.internal
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
VISION_MODEL=llava
GPU_ENABLED=false

# --- AWS (cloud deployment — S3, DynamoDB, OpenSearch, Redis) ---
# Region where NanoClaw infrastructure is deployed
AWS_REGION=ap-southeast-1
# Use a named profile from ~/.aws/config (SSO or IAM credentials)
# AWS_PROFILE=nanoclaw
# S3 bucket for document uploads and user data (created by Terraform)
# Format: nanoclaw-data-{account_id}
DATA_BUCKET=
# Redis URL for upload processing queue (ElastiCache in prod, local in dev)
REDIS_URL=redis://localhost:6379

# --- Cloud mode (multi-user NanoClaw deployment) ---
# Set to 'cloud' to activate AWS services (Secrets Manager, DynamoDB, OpenSearch, etc.)
# Leave unset for local PocketClaw single-user mode.
# NANOCLAW_ENV=cloud

# --- PocketClaw runtime config ---
BATCH_WINDOW_MS=5000
CONTAINER_MEMORY_LIMIT=2g

# --- Local paths (relative to user home unless absolute) ---
VAULT_PATH=~/.pocketclaw/vault
WATCH_PATHS_ROOT=~/.pocketclaw/watch
LOG_PATH=~/.pocketclaw/logs
